## 6) Full minimal example (all steps in one place)

> **Note:** This is deliberately compact to focus on the Blast + Stress Solver flow. It doesn’t include PhysX code—add rigid bodies & shapes for each `TkActor` to see motion.

```cpp
#include <vector>
#include <cstdlib>
#include "NvBlastTk.h"
#include "NvBlastTkFramework.h"
#include "NvBlastTkAsset.h"
#include "NvBlastTkActor.h"
#include "NvBlastTkFamily.h"
#include "NvBlastExtAuthoring.h"
#include "NvBlastExtAuthoringFractureTool.h"
#include "NvBlastExtAuthoringBondGenerator.h"
#include "NvBlastExtAuthoringTypes.h"
#include "NvBlastExtStressSolver.h"
#include "NvBlastGlobals.h"
#include "NvCMath.h"

using namespace Nv::Blast;

struct Destructible
{
    TkFramework*     framework{};
    TkAsset*         tkAsset{};
    TkActor*         tkActor{};
    ExtStressSolver* stress{};
};

Destructible makeDestructibleCube()
{
    Destructible out{};
    out.framework = NvBlastTkFrameworkCreate();

    // --- Build unit-cube mesh
    static const float V[] = {
        -0.5f,-0.5f,-0.5f,  +0.5f,-0.5f,-0.5f,
        +0.5f,+0.5f,-0.5f,  -0.5f,+0.5f,-0.5f,
        -0.5f,-0.5f,+0.5f,  +0.5f,-0.5f,+0.5f,
        +0.5f,+0.5f,+0.5f,  -0.5f,+0.5f,+0.5f
    };
    static const uint32_t I[] = {
        0,1,2, 0,2,3,  4,6,5, 4,7,6,
        0,4,5, 0,5,1,  3,2,6, 3,6,7,
        0,3,7, 0,7,4,  1,5,6, 1,6,2
    };
    Mesh* mesh = NvBlastExtAuthoringCreateMeshOnlyTriangles(V, 8, const_cast<uint32_t*>(I), 36);

    // --- Fracture into Voronoi cells
    FractureTool* ft = NvBlastExtAuthoringCreateFractureTool();
    Mesh* meshes[] = { mesh };
    ft->setSourceMeshes(meshes, 1, nullptr);

    const uint32_t cellCount = 32;
    std::vector<NvcVec3> pts;
    pts.reserve(cellCount);
    for (uint32_t i = 0; i < cellCount; ++i) {
        float x = -0.5f + (float)rand()/RAND_MAX;
        float y = -0.5f + (float)rand()/RAND_MAX;
        float z = -0.5f + (float)rand()/RAND_MAX;
        pts.push_back({x,y,z});
    }
    ft->voronoiFracturing(0, cellCount, pts.data(), /*replaceChunk=*/false);
    ft->finalizeFracturing();

    // --- Bond & chunk descriptors
    BlastBondGenerator* bondGen = NvBlastExtAuthoringCreateBondGenerator(nullptr);
    std::vector<bool> isSupport(ft->getChunkCount(), true);
    std::vector<NvBlastBondDesc> bonds;
    std::vector<NvBlastChunkDesc> chunks;
    bondGen->buildDescFromInternalFracture(ft, isSupport, bonds, chunks);

    // --- Cook low-level asset
    NvBlastAssetDesc llDesc{};
    llDesc.chunkCount = (uint32_t)chunks.size();
    llDesc.chunkDescs = chunks.data();
    llDesc.bondCount  = (uint32_t)bonds.size();
    llDesc.bondDescs  = bonds.data();

    void* mem = NVBLAST_ALLOC(NvBlastGetAssetMemorySize(&llDesc));
    NvBlastAsset* llAsset = NvBlastCreateAsset(mem, &llDesc, nullptr);

    // --- TkAsset + Actor + Family
    out.tkAsset = out.framework->createAsset(llAsset, nullptr, 0, /*own*/ true);
    TkActorDesc ad{}; ad.asset = out.tkAsset;
    out.tkActor = out.framework->createActor(ad);
    TkFamily& family = out.tkActor->getFamily();

    // --- Stress Solver
    out.stress = ExtStressSolver::create(*family.getFamilyLL());
    out.stress->setAllNodesInfoFromLL(1000.0f); // density
    ExtStressSolverSettings s{};
    s.compressionElasticLimit = 1.0e5f; s.compressionFatalLimit = 5.0e5f;
    s.shearElasticLimit = s.shearFatalLimit = -1.0f;
    s.tensionElasticLimit = s.tensionFatalLimit = -1.0f;
    out.stress->setSettings(s);
    out.stress->notifyActorCreated(*out.tkActor->getActorLL());

    // Clean up authoring objects (asset is now owned by TkAsset)
    ft->release(); mesh->release();

    return out;
}

// Example: hit the cube with a force at a point in the cube’s local space
void hit(Destructible& d, const NvcVec3& localPos, const NvcVec3& localForce)
{
    d.stress->addForce(*d.tkActor->getActorLL(), localPos, localForce);
}

void step(Destructible& d)
{
    d.stress->update();

    if (d.stress->getOverstressedBondCount() > 0)
    {
        TkFamily& family = d.tkActor->getFamily();

        std::vector<TkActor*> actors(family.getActorCount());
        family.getActors(actors.data(), (uint32_t)actors.size());

        for (TkActor* a : actors) if (a) {
            NvBlastFractureBuffers cmds{};
            d.stress->generateFractureCommands(*a->getActorLL(), cmds);
            family.applyFracture(&cmds);
            // After apply, Blast will dispatch split events to listeners (spawn PhysX actors there)
        }
    }
}
```

> **Add your physics**: Create a rigid body for `d.tkActor` initially; on split events from `TkFamily` create new bodies for child `TkActor`s and delete the parent body. Apply the same gameplay impulse to PhysX and to `ExtStressSolver::addForce(...)`. TkActor and TkFamily APIs, including `getActorLL()`, `getActors`, and `applyFracture`, are documented in the Toolkit API and class references. ([NVIDIA Omniverse][1])

