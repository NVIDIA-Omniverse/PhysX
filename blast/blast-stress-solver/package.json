{
  "name": "blast-stress-solver",
  "version": "0.1.0",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./stress_solver.wasm": "./dist/stress_solver.wasm"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ./scripts/copy-dist.js",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.9.3"
  }
}


