class PhysxParticleSystem "PhysxParticleSystem" (
    customData = {
        string userDocBrief = "WARNING: This is a draft API; the design is not fixed and may change in the future."
    }
)
{
    float contactOffset = -inf (
        customData = {
            string userDocBrief = "Contact offset used for collisions with non-particle objects such as rigid or deformable bodies."
        }
        displayName = "Contact Offset"
    )
    uniform bool doubleSided = 0 (
        customData = {
            string userDocBrief = """Although some renderers treat all parametric or polygonal
        surfaces as if they were effectively laminae with outward-facing
        normals on both sides, some renderers derive significant optimizations
        by considering these surfaces to have only a single outward side,
        typically determined by control-point winding order and/or 
        orientation."""
        }
    )
    bool enableCCD = 0 (
        customData = {
            string userDocBrief = "Enable continuous collision detection for particles to help avoid tunneling effects."
        }
        displayName = "Enable CCD"
    )
    float3[] extent (
        customData = {
            string userDocBrief = """Extent is a three dimensional range measuring the geometric
        extent of the authored gprim in its own local space (i.e."""
        }
    )
    float fluidRestOffset = -inf (
        customData = {
            string userDocBrief = "Rest offset used for fluid-fluid particle interactions."
        }
        displayName = "Fluid Rest Offset"
    )
    bool globalSelfCollisionEnabled = 1 (
        customData = {
            string userDocBrief = "If True, self collisions follow particle-object-specific settings."
        }
        displayGroup = "Advanced"
        displayName = "Global Self Collision Enabled"
    )
    float maxDepenetrationVelocity = inf (
        customData = {
            string userDocBrief = "The maximum velocity permitted to be introduced by the solver to depenetrate intersecting particles."
        }
        displayGroup = "Advanced"
        displayName = "Max Depenetration Velocity"
    )
    int maxNeighborhood = 96 (
        customData = {
            string userDocBrief = "Defines how many particle neighbors per particle may be considered for interaction computations."
        }
        displayGroup = "Advanced"
        displayName = "Max Neighborhood"
    )
    float maxVelocity = inf (
        customData = {
            string userDocBrief = "Maximum particle velocity."
        }
        displayName = "Max Velocity"
    )
    float neighborhoodScale = 1.01 (
        customData = {
            string userDocBrief = "Defines by how much the default neighborhood volume is inflated to ensure that all relevant neighboring particles are found while particles interact."
        }
        displayGroup = "Advanced"
        displayName = "Neighborhood Scale"
    )
    bool nonParticleCollisionEnabled = 1 (
        customData = {
            string userDocBrief = "Enable or disable particle collision with nonparticle objects for all particles in the system."
        }
        displayGroup = "Advanced"
        displayName = "Nonparticle-Objects Collision Enabled"
    )
    uniform token orientation = "rightHanded" (
        allowedTokens = ["rightHanded", "leftHanded"]
        customData = {
            string userDocBrief = """Orientation specifies whether the gprim's surface normal 
        should be computed using the right hand rule, or the left hand rule."""
        }
    )
    float particleContactOffset = 0.05 (
        customData = {
            string userDocBrief = "Contact offset used for interactions between particles."
        }
        displayName = "Particle Contact Offset"
    )
    bool particleSystemEnabled = 1 (
        customData = {
            string userDocBrief = "Enable or disable the particle system."
        }
        displayName = "Particle System Enabled"
    )
    color3f[] primvars:displayColor (
        customData = {
            string userDocBrief = '''It is useful to have an "official" colorSet that can be used
        as a display or modeling color, even in the absence of any specified
        shader for a gprim.'''
        }
    )
    float[] primvars:displayOpacity (
        customData = {
            string userDocBrief = """Companion to displayColor that specifies opacity, broken
        out as an independent attribute rather than an rgba color, both so that
        each can be independently overridden, and because shaders rarely consume
        rgba parameters."""
        }
    )
    rel proxyPrim (
        customData = {
            string userDocBrief = '''The proxyPrim relationship allows us to link a
        prim whose purpose is "render" to its (single target)
        purpose="proxy" prim.'''
        }
    )
    uniform token purpose = "default" (
        allowedTokens = ["default", "render", "proxy", "guide"]
        customData = {
            string userDocBrief = """Purpose is a classification of geometry into categories that 
        can each be independently included or excluded from traversals of prims 
        on a stage, such as rendering or bounding-box computation traversals."""
        }
    )
    float restOffset = -inf (
        customData = {
            string userDocBrief = "Rest offset used for collisions with non-particle objects such as rigid or deformable bodies."
        }
        displayName = "Rest Offset"
    )
    rel simulationOwner (
        customData = {
            string userDocBrief = "Single PhysicsScene that simulates this particle system."
        }
        displayName = "Simulation Owner"
    )
    float solidRestOffset = -inf (
        customData = {
            string userDocBrief = "Rest offset used for solid-solid or solid-fluid particle interactions."
        }
        displayName = "Solid Rest Offset"
    )
    int solverPositionIterationCount = 16 (
        customData = {
            string userDocBrief = "Number of solver iterations for position."
        }
        displayGroup = "Advanced"
        displayName = "Solver Position Iteration Count"
    )
    token visibility = "inherited" (
        allowedTokens = ["inherited", "invisible"]
        customData = {
            string userDocBrief = '''Visibility is meant to be the simplest form of "pruning" 
        visibility that is supported by most DCC apps.'''
        }
    )
    float3 wind = (0, 0, 0) (
        customData = {
            string userDocBrief = "The wind applied to the current particle system."
        }
        displayName = "Wind"
    )
    uniform token[] xformOpOrder (
        customData = {
            string userDocBrief = """Encodes the sequence of transformation operations in the
        order in which they should be pushed onto a transform stack while
        visiting a UsdStage's prims in a graph traversal that will effect
        the desired positioning for this prim and its descendant prims."""
        }
    )
}

