#usda 1.0
(
    customLayerData = {
        dictionary renderSettings = {
        }
    }
    defaultPrim = "SpatialTendonTest"
    metersPerUnit = 1
    upAxis = "Z"
)


def PhysicsScene "physicsScene"
{
    vector3f physics:gravityDirection = (0, 0, -1)
    float physics:gravityMagnitude = 1000
}

def Xform "SpatialTendonTest" (
    prepend apiSchemas = ["PhysicsArticulationRootAPI", "PhysxArticulationAPI"]
)
{

    bool physxArticulation:enabledSelfCollisions = 0

    def Cube "body0" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysxTendonAttachmentLeafAPI:leaf"]
    )
    {
        float3 physics:diagonalInertia = (0.00001, 0.00001, 0.00001)
        float physics:mass = 0.008
        float physxTendon:leaf:gearing = 13
        point3f physxTendon:leaf:localPos = (14, 15, 16)
        float physxTendon:leaf:lowerLimit = 17
        uniform token physxTendon:leaf:parentAttachment = "a1"
        rel physxTendon:leaf:parentLink = </SpatialTendonTest/body2>
        float physxTendon:leaf:restLength = 19
        float physxTendon:leaf:upperLimit = 18
        color3f[] primvars:displayColor = [(0.7, 0.1, 0.1)]
        double size = 1
        quatf xformOp:orient = (1, 0, 0, 0)
        float3 xformOp:scale = (1.0, 0.4, 0.2)
        float3 xformOp:translate = (0, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    def Cube "body1" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float3 physics:diagonalInertia = (0.00001, 0.00001, 0.00001)
        float physics:mass = 0.008
        color3f[] primvars:displayColor = [(0.1, 0.1, 0.7)]
        double size = 1
        quatf xformOp:orient = (1, 0, 0, 0)
        float3 xformOp:scale = (1.0, 0.4, 0.2)
        float3 xformOp:translate = (10, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    def Cube "body2" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysxTendonAttachmentAPI:a1"]
    )
    {
        float3 physics:diagonalInertia = (0.00001, 0.00001, 0.00001)
        float physics:mass = 0.008
        float physxTendon:a1:gearing = 9
        point3f physxTendon:a1:localPos = (10, 11, 12)
        uniform token physxTendon:a1:parentAttachment = "body0"
        rel physxTendon:a1:parentLink = </SpatialTendonTest/body4>
        color3f[] primvars:displayColor = [(0.1, 0.1, 0.7)]
        double size = 1
        quatf xformOp:orient = (1, 0, 0, 0)
        float3 xformOp:scale = (1.0, 0.4, 0.2)
        float3 xformOp:translate = (20, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    def Cube "body3" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI"]
    )
    {
        float3 physics:diagonalInertia = (0.00001, 0.00001, 0.00001)
        float physics:mass = 0.008
        color3f[] primvars:displayColor = [(0.1, 0.1, 0.7)]
        double size = 1
        quatf xformOp:orient = (1, 0, 0, 0)
        float3 xformOp:scale = (1.0, 0.4, 0.2)
        float3 xformOp:translate = (30, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    def Cube "body4" (
        prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysicsMassAPI", "PhysxTendonAttachmentRootAPI:body0"]
    )
    {
        float3 physics:diagonalInertia = (0.00001, 0.00001, 0.00001)
        float physics:mass = 0.008
        float physxTendon:body0:damping = 2
        float physxTendon:body0:gearing = 42
        float physxTendon:body0:limitStiffness = 3
        point3f physxTendon:body0:localPos = (4, 5, 6)
        float physxTendon:body0:offset = 7
        float physxTendon:body0:stiffness = 8
        color3f[] primvars:displayColor = [(0.1, 0.1, 0.7)]
        double size = 1
        quatf xformOp:orient = (1, 0, 0, 0)
        float3 xformOp:scale = (1.0, 0.4, 0.2)
        float3 xformOp:translate = (40, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    // fixed base
    def PhysicsFixedJoint "rootJoint"
    {
        rel physics:body1 = </SpatialTendonTest/body0>
    }

    def PhysicsRevoluteJoint "revJoint01"
    {
        uniform token physics:axis = "Y"
        rel physics:body0 = </SpatialTendonTest/body0>
        rel physics:body1 = </SpatialTendonTest/body1>
        point3f physics:localPos0 = (0.5, 0, 0)
        point3f physics:localPos1 = (-0.5, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
    }

    def PhysicsRevoluteJoint "revJoint12"
    {
        uniform token physics:axis = "Y"
        rel physics:body0 = </SpatialTendonTest/body1>
        rel physics:body1 = </SpatialTendonTest/body2>
        point3f physics:localPos0 = (0.5, 0, 0)
        point3f physics:localPos1 = (-0.5, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
    }

    def PhysicsRevoluteJoint "revJoint23"
    {
        uniform token physics:axis = "Y"
        rel physics:body0 = </SpatialTendonTest/body2>
        rel physics:body1 = </SpatialTendonTest/body3>
        point3f physics:localPos0 = (0.5, 0, 0)
        point3f physics:localPos1 = (-0.5, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
    }

    def PhysicsRevoluteJoint "revJoint34"
    {
        uniform token physics:axis = "Y"
        rel physics:body0 = </SpatialTendonTest/body3>
        rel physics:body1 = </SpatialTendonTest/body4>
        point3f physics:localPos0 = (0.5, 0, 0)
        point3f physics:localPos1 = (-0.5, 0, 0)
        quatf physics:localRot0 = (1, 0, 0, 0)
        quatf physics:localRot1 = (1, 0, 0, 0)
    }
}
