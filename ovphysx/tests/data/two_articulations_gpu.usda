#usda 1.0
(
    defaultPrim = "World"
    endTimeCode = 100
    metersPerUnit = 1
    startTimeCode = 0
    timeCodesPerSecond = 60
    upAxis = "Z"
)

def Xform "World"
{
    def PhysicsScene "physicsScene"
    {
        vector3f physics:gravityDirection = (0, 0, -1)
        float physics:gravityMagnitude = 9.81
        bool physxScene:enableGpuDynamics = 1
        token physxScene:broadPhaseType = "GPU"
    }

    def Xform "articulation" (
        apiSchemas = ["PhysicsArticulationRootAPI"]
    )
    {
        def PhysicsFixedJoint "rootJoint"
        {
            rel physics:body1 = </World/articulation/articulationLink0>
            point3f physics:localPos0 = (-2.5, 0, 24)
            point3f physics:localPos1 = (0, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        def Capsule "articulationLink0" (
            apiSchemas = ["PhysicsCollisionAPI", "PhysicsRigidBodyAPI"]
        )
        {
            uniform token axis = "X"
            double height = 0.125
            color3f[] primvars:displayColor = [(1, 0, 0)]
            double radius = 0.125
            quatf xformOp:orient = (1, 0, 0, 0)
            float3 xformOp:scale = (1, 1, 1)
            double3 xformOp:translate = (-2.5, 0, 24)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
        }

        def PhysicsRevoluteJoint "articulatedRevoluteJoint1" (
            apiSchemas = ["PhysicsDriveAPI:angular"]
        )
        {
            float drive:angular:physics:damping = 100000000
            float drive:angular:physics:targetVelocity = 0
            uniform token physics:axis = "Y"
            rel physics:body0 = </World/articulation/articulationLink0>
            rel physics:body1 = </World/articulation/articulationLink1>
            point3f physics:localPos0 = (0.25, 0, 0)
            point3f physics:localPos1 = (-0.25, 0, 0)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
            float physics:lowerLimit = -5.625
            float physics:upperLimit = 5.625
        }

        def Capsule "articulationLink1" (
